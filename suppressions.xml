<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://dependency-check.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
    Archivo de supresión para OWASP Dependency Check
    -->

    <!-- Log4Shell - referencia educativa del prototipo -->
    <suppress>
        <notes><![CDATA[
            CVE-2021-44228 (Log4Shell) - Se mantiene como referencia educativa en el proyecto
        ]]></notes>
        <cve>CVE-2021-44228</cve>
        <cve>CVE-2021-45046</cve>
    </suppress>

    <!-- Dependencias de desarrollo y testing -->
    <suppress>
        <notes><![CDATA[
            Dependencias utilizadas solo en entorno de desarrollo y pruebas
        ]]></notes>
        <gav regex="true">^.*junit.*$</gav>
        <gav regex="true">^.*mockito.*$</gav>
        <gav regex="true">^.*hamcrest.*$</gav>
    </suppress>

    <!-- Herramientas de build -->
    <suppress>
        <notes><![CDATA[
            Herramientas de Maven y build que no se despliegan en producción
        ]]></notes>
        <gav regex="true">^.*maven.*$</gav>
        <gav regex="true">^.*spotbugs.*$</gav>
        <gav regex="true">^.*dependency-check.*$</gav>
    </suppress>

    <!-- Falsos positivos SLF4J -->
    <suppress>
        <notes><![CDATA[
            Falsos positivos comunes en SLF4J
        ]]></notes>
        <gav regex="true">^.*slf4j.*$</gav>
    </suppress>
</suppressions>